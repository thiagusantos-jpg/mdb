# ==============================================
# DUBAIRRO MVP — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ==============================================

# --- Supabase ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_DB_PASS=<database-password>

# --- JWT ---
JWT_SECRET=<secret-aleatorio-min-32-chars>
JWT_REFRESH_SECRET=<secret-aleatorio-min-32-chars>

# --- Mobne API ---
MOBNE_API_URL=https://apiexternal.mobne.com.br/api/v1
MOBNE_API_KEY=zikBlcp7B/R2HyKAs+y/Qrz1KeihAmGI8yNdKHDblssMBMrJSZjY8pJC5qFO59MIz7ohVFJ4UAQNcQc0t96qLQ==

# --- Cron (Vercel) ---
CRON_SECRET=<secret-para-proteger-endpoint-do-cron>

# --- Sistema ---
# UUID do usuário que recebe os dados do cron automático
# Criar um usuário "sistema" no banco e colocar o ID aqui
SYSTEM_USER_ID=<uuid-do-usuario-sistema>

# --- CORS ---
CORS_ORIGIN=*

# --- Frontend (Vite — prefixo VITE_ obrigatório) ---
VITE_API_URL=/api
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>
